<div class="relative bg-white">
    <div class="mx-auto px-4 sm:px-6">
        <div class="flex justify-center items-center py-6 md:justify-start md:space-x-10">
            <!-- shop name -->
            <div class="flex justify-start lg:flex-1 truncate">
                <h1 class="text-xl font-bold truncate">{{shop.name}}</h1>
            </div>

            <!-- NAVIGATION MENU -->
            <nav class="hidden md:flex space-x-5">
                <div class="relative">
                    {% for link in linklists.main-menu.links %}
                        <a href="{{ link.url }}" class="text-base text-gray-500 hover:text-gray-900">{{ link.title }}</a>
                    {% endfor %}
                </div>
            </nav>

            <div class="hidden md:flex items-center justify-end md:flex-1 space-x-5">
                <a href="{{ routes.cart_url }}" class="whitespace-nowrap text-base text-gray-500 hover:text-gray-900">
                    Cart
                </a>

                <a href="{{ routes.login_url }}" class="text-base text-gray-500 hover:text-gray-900">Login</a>
                <a href="{{ routes.register_url }}" class="text-base text-gray-500 hover:text-gray-900">Register</a>
            </div>
        </div>
    </div>
</div>